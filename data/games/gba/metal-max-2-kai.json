  "descriptions": [
    {
      "text": "Metal Max 2 (メタルマックス2) is the second entry in the Metal Max series. It is a vehicle combat RPG published in Japan by Data East in 1993 for the Super Famicom. Ten years later, the game was ported to the Game Boy Advance with a few new bounties by Now Production under the title Metal Max 2 Kai. In December 2011, a full remake with upgraded graphics in the vein of Metal Max 3 and using its game engine was released in Japan for the Nintendo DS and titled Metal Max 2 Reloaded.",
      "lang": "en",
      "source": "wikipedia_en"
    }

  "descriptions": [
    {
      "text": "Chicken Shoot is a gallery shooting game based on free 2003 flash game of the same name. Played from the first-person perspective, the player points the Wii remote and shoots all chickens that fly across the screen.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Chicken Shoot is a video game developed by Toontraxx. It first released online in 2000 for Microsoft Windows and has since been released for Nintendo DS, Wii, and Game Boy Advance.\nThe Windows version received positive reviews, while reviews for the Game Boy Advance version were mixed, and both the Wii and DS versions were panned by critics.",
      "lang": "en",
      "source": "wikipedia_en"
    }

  "descriptions": [
    {
      "text": "A GBA game released by Konami in December 2002. It is the first video game adaptation made for Mirumo de Pon.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "A festival is coming up at Mirumo Village in the Fairy World. However, the Warumo Gang has stolen the Legendary Golden Maracas from the Royal Family, and without it Mirumo cannot cast any magic! Journey with Mirumo and Kaede across the Fairy World to reclaim the Golden Maracas from the Warumo Gang and restore the festiaval for everyone.",
      "lang": "en",
      "source": "igdb_storyline"
    }

  "descriptions": [
    {
      "text": "The main characters try to use the sweet smell of sweets as a signal to tell Tama-chan's mother where the lost Tama-chan is. Collect recipes and ingredients to make sweets in over 50 mini-games.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The four main characters from the previous work, Lapi, Nyam, Pochi, and Mark, meet Tama-chan, a crying seal who has been separated from his mother.\nAn exciting, fun, and slightly sad story unfolds between the four and Tama-chan.",
      "lang": "en",
      "source": "igdb_storyline"
    }

  "descriptions": [
    {
      "text": "When included in the Mother 1+2 bundle, Mother (Earthbound Beginnings in the West) received an exclusive equippable item, the Easy Ring, available from the start, which makes the game more balanced (therefore easier than the original version).",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Mother follows the young Ninten as he uses his great-grandfather's studies on psychic powers to fight hostile, formerly inanimate objects and other enemies. His adventure leads him to new friends and eventually uncovering an alien plot that must be stopped.",
      "lang": "en",
      "source": "igdb_storyline"

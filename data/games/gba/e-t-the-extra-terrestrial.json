  "descriptions": [
    {
      "text": "Players must save E.T. from the government agents, scientists, and law enforcement officers that are trying to catch him while attempting to assemble a transmitter that will allow E.T. to phone home.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "E.T. is in serious trouble, and needs your help! You must race against time to save him from the government agents, scientists and law enforcement officers that are trying to catch him. Your Mission: Assemble the transmitter that will allow E.T. to \"phone home\", then arrange for him to be picked up by his spaceship before it's too late! E.T. needs your help; go save him...",
      "lang": "en",
      "source": "igdb_storyline"
    }

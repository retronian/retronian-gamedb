  "descriptions": [
    {
      "text": "Driver 2 Advance is a top-down driving and action game developed by Sennari Interactive and published by Infogrames in 2002 for the Game Boy Advance. It is a handheld adaptation of Driver 2: Back on the Streets, following the same storyline of undercover cop Tanner and his partner Jones investigating a criminal network. The game features mission-based gameplay across multiple international locations. Players can drive various vehicles, complete objectives, and evade pursuing enemies. The design is adapted to the Game Boy Advance’s hardware, with an overhead perspective replacing the original’s 3D environments.",
      "lang": "en",
      "source": "igdb"

    {
      "text": "2003년 액션 어드벤처 게임",
      "lang": "ko",
      "source": "wikidata"
    },
    {
      "text": "video game based on the Crouching Tiger, Hidden Dragon film by Ang Lee",
      "lang": "en",
      "source": "wikidata"
    },
    {
      "text": "jeu vidéo d'action-aventure développé par Bergsala Lightweight et Genki et édité en 2003 par ESP et Ubisoft sur PlayStation 2, Xbox, Game Boy Advance",
      "lang": "fr",
      "source": "wikidata"
    },
    {
      "text": "Crouching Tiger, Hidden Dragon is a beat 'em up video game based on the 2000 film of the same name by Ang Lee. Players may play as Li Mu Bai, Yu Shu Lien, Jen, and Lo. The game uses the film score as its soundtrack which features music composed by Tan Dun with solos by cellist Yo-Yo Ma. A GameCube version of the game was planned, but cancelled for unknown reasons.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "Tigre et Dragon (ou Crouching Tiger, Hidden Dragon en anglais) est un jeu vidéo d'action-aventure développé par Bergsala Lightweight et Genki et édité en 2003 par ESP et Ubisoft sur PlayStation 2, Xbox, Game Boy Advance. Le jeu est basé sur l'univers du film homonyme de Ang Lee.",
      "lang": "fr",
      "source": "wikipedia_fr"
    },
    {
      "text": "『臥虎伝』は、アン・リー監督の同名映画（2000年公開）を原作としたビートアップビデオゲームである。プレイヤーは、李慕白、俞昭蓮、ジェン、ローのいずれかのキャラクターを操作できる。ゲームのサウンドトラックには、タン・ダンが作曲し、セルリストのヨヨ・マがソロを披露する映画のスコアが使用されている。ゲームキューブ版の制作が計画されたが、理由は不明のまま中止となった。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

  "descriptions": [
    {
      "text": "The Lord of the Rings: The Third Age for Game Boy Advance is a turn-based tactics game released in 2004. The game consists of 2 campaigns (Good and Evil). In each campaign the player chooses a commander. As the player completes missions and progresses through the campaign, they are able to use experience points to purchase skills and equipment upgrades in order to enhance the performance of their primary and secondary heroes.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The Lord of the Rings: The Third Age for the Game Boy Advance encompasses the entire Lord of the Rings trilogy, but does so in a unique turn-based strategy formula.",

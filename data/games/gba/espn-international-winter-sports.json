  "descriptions": [
    {
      "text": "ESPN International Winter Sports 2002, known in Japan as Hyper Sports 2002 Winter (ハイパースポーツ2002 WINTER, Haipā Supōtsu 2002 Wintā), is the name of two sports video games released in 2002 by Konami, one for the PlayStation 2, Xbox, and GameCube, and the other for the Game Boy Advance. In Japan the game is part of the Hyper Sports series, known internationally as the Track & Field series.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ESPN International Winter Sports 2002』は、日本国内では『ハイパースポーツ2002 WINTER』として知られており、コナミから2002年に発売されたスポーツビデオゲームの名称です。このゲームは、プレイステーション2、Xbox、ゲームキューブ用と、ゲームボーイアドバンス用という2つのバージョンが存在します。日本においては、このゲームは「ハイパースポーツシリーズ」の一部であり、国際的には「トラック＆フィールドシリーズ」として知られています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

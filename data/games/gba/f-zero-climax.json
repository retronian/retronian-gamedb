  "descriptions": [
    {
      "text": "F-Zero Climax is the sixth installment in the F-Zero series and the third to be released for the Game Boy Advance. This is the first F-Zero game to have a built-in track editor without the need for an expansion or add-on. Custom tracks can be saved to one of thirty slots for future use and they can be exchanged with other players via link cable. If memory becomes full or link cable connection cannot be done, the game can generate a password for the track; when it is input on any F-Zero Climax cartridge, the password will generate the track instantly.",
      "lang": "en",
      "source": "igdb"

  "descriptions": [
    {
      "text": "Tony Hawk's American Sk8land is a skateboarding video game in the Tony Hawk's series. The game, a companion title to Tony Hawk's American Wasteland, was published by Activision in 2005 as the first handheld release in the series for the Nintendo DS, and the fifth to appear on Game Boy Advance. It was the first third-party game released for the Nintendo DS supporting online play.",
      "lang": "en",
      "source": "wikipedia_en"
    }

    },
    {
      "text": "Hot Wheels: All Out is a racing video game developed by British studio TwoFiveSix and published by Destination Software and ZOO Digital Publishing. It was released in 2006 exclusively for the Game Boy Advance.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "Hot Wheels: All Out es un videojuego de carreras desarrollado por TwoFiveSix y publicado por Destination Software y Zoo Digital Publishing para Game Boy Advance. Fue lanzado el 13 de septiembre de 2006 en América del Norte y el 24 de noviembre de 2006 en Europa.",
      "lang": "es",
      "source": "wikipedia_es"
    },
    {
      "text": "『ホットウィール：オールアウト』は、イギリスのスタジオTwoFiveSixが開発し、Destination SoftwareとZOO Digital Publishingから発売されたレーシングビデオゲームです。2006年にゲームボーイアドバンス専用タイトルとしてリリースされました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

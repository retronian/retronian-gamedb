  "descriptions": [
    {
      "text": "The third game based on the DUEL MASTERS anime. Gamers will get back in the card-game dueling with access to all 600 released cards, an in-depth storyline featuring characters from the anime, and more.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Recent tournament titles have put you at the top of the competitive circuit. Fans want your autograph, your smiling face adorns many a zine cover, and shop owners argue over who gets to be your sponsor. But all is not well when your pal Shobu goes missing and kids start reporting real-life sightings of famous Duel Masters creatures in town. Winning tournament isn't enough if you want to solve the mystery of missing Shobu.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

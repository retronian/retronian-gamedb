  "descriptions": [
    {
      "text": "Blue and Red, the lead characters in Gunstar Super Heroes, must once again keep a stone of great power from falling into the hands of an evil empire intent on resurrecting the God of Ruin. Blue and Red take on the same adventure using different paths, effectively making for two unique play-through experiences. Players will tackle six wildly inventive levels and take on gigantic bosses that fill the entire Game Boy Advance screen.",
      "lang": "en",
      "source": "igdb"

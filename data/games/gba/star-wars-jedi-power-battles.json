  "descriptions": [
    {
      "text": "2001 video game",
      "lang": "en",
      "source": "wikidata"
    },
    {
      "text": "Star Wars Episode I: Jedi Power Battles is a 2000 action video game based on the 1999 film Star Wars: Episode I – The Phantom Menace. It was released for the PlayStation and Dreamcast in 2000, followed by the Game Boy Advance in 2001 (under the title Star Wars: Jedi Power Battles). A remastered version of the game was released for Windows, Nintendo Switch, PlayStation 4, PlayStation 5, Xbox One, and Xbox Series X/S in January 2025.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『スター・ウォーズ エピソード１：ジェダイ・パワー・バトルズ』は、1999年の映画『スター・ウォーズ エピソード１／ファントム・メナス』を原作とした2000年のアクションビデオゲームです。2000年にはPlayStationとDreamcast向けに発売され、その後2001年にはゲームボーイアドバンス（『スター・ウォーズ：ジェダイ・パワー・バトルズ』というタイトルで）に移植されました。本作のリマスター版は、2025年1月にWindows、Nintendo Switch、PlayStation 4、PlayStation 5、Xbox One、Xbox Series X/S向けにリリースされています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

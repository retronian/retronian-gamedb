  "descriptions": [
    {
      "text": "Hamepane Tokyo Mew Mew is a Puzzle game, developed by WinkySoft and published by Takara, which was released in Japan in 2002.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "\"My name is Ichigo Momomiya. Today I'm on a date with Aoyama! Although it was supposed to be a fun day, Quiche ruined it by stealing Masha's memory chip! The memory chip has our Tokyo Mew Mew secret identities stored on it!! Not only that, the memory chips broke apart! If we don't collect the memory chips faster than Quiche, Aoyama-kun... no, our secret identities will be revealed to everyone!? I can't imagine such a thing! Complete the puzzles to get the memory chips back!\"",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

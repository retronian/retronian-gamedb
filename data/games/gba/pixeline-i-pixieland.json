  "descriptions": [
    {
      "text": "Pixeline i Pixieland is a Danish adventure game developed and published by Krea Medie for the Game Boy Advance. It is a port of the original PC game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The gnomes and fairies in Pixieland haven't spoken to one another for over a hundred years. Pixeline is planning to help them reunite with a big party.",

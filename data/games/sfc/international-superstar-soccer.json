  "descriptions": [
    {
      "text": "International Superstar Soccer is a football video game developed by Konami for the Super Nintendo Entertainment System. It is known as the best soccer game available for any 16-bit systems, mostly due to its lifelike approach, innovative for the time, that showed diversified players in the same team, with an adult look and back numbers on their respective jerseys, corresponding to real-life players of the time.",
      "lang": "en",
      "source": "igdb"
    },

  "descriptions": [
    {
      "text": "Soccer Kid is a side-scrolling platform game released in 1993 for various home computers and consoles. Players control a young boy who uses his soccer ball to defeat enemies and overcome obstacles. The game’s story follows his quest to recover pieces of the World Cup trophy scattered across different countries. Levels feature themed environments based on locations such as England, Italy, Russia, Japan, and the United States.",
      "lang": "en",
      "source": "igdb"

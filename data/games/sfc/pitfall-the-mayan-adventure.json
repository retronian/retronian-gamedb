  "descriptions": [
    {
      "text": "Pitfall: The Mayan Adventure is a side-scrolling action game where players assume the role of adventurer Pitfall Harry Jr. as he searches for his father, Pitfall Harry. The game features various environments such as Mayan jungles, waterfalls, and deserted mines. Players can bungee jump and boomerang their way through 13 levels.",
      "lang": "en",
      "source": "igdb"

  "descriptions": [
    {
      "text": "Arcade's Greatest Hits: The Atari Collection 1 is a collection of Atari arcade games for the Sega Saturn, PlayStation, and Super Nintendo Entertainment System.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Are you tired of combos, adventure quests, fatalities, hidden worlds and thick instruction manuals? Want a blast from the past? Try Midway Presents: Arcade's Greatest Hits/The Atari Collection 1 for the PlayStation, featuring six of Atari's most popular coin-op games from the late 1970s and early 1980s. Play Asteroids, Battlezone, Centipede, Missile Command, Super Breakout and Tempest.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

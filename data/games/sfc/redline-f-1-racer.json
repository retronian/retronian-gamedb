  "descriptions": [
    {
      "text": "North American port of Aguri Suzuki F-1 Super Driving. The only difference is that this version has no relation with the driver in a licensing standpoint, but he is still depicted in-game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Aguri Suzuki F-1 Super Driving, released as Redline F-1 Racer in North America, is a Formula One racing simulator game for the Super Nintendo Entertainment System and Game Boy. The game is named after and sponsored by the Japanese Formula 1 driver, Aguri Suzuki; his likeness and imagery were retained in the North American version despite the name change.",
      "lang": "en",
      "source": "wikipedia_en"
    }

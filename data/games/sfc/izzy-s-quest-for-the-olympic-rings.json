  "descriptions": [
    {
      "text": "Izzy's Quest for the Olympic Rings is a 1995 platformer video game developed by Alexandria and published by U.S. Gold for the Sega Genesis and the Super Nintendo Entertainment System.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "イジーのオリンピックリングを求めては、1995年にアレクサンドリアが開発し、U.S. Goldがセガジェネシスとスーパーファミコン向けに発売したプラットフォーマービデオゲームです。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

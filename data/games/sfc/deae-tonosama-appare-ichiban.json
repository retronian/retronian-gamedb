  "descriptions": [
    {
      "text": "The Earth is in danger, the Tokugawa shogunate has been overrun by an extra-terrestrial evil force, and only two morons have the power to save the day. Play as either a daft French nobleman or an idiot Japanese lord and crush your foes with style. East meets west in this quirky but entertaining action game that unfolds across the world — and beyond!",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Deae Tonosama: Appare Ichiban is a 1995 beat 'em up video game developed and published by Sunsoft for the Super Famicom. In 2025, the game was released in English under the name Feudal Bros: Tonosama #1.",
      "lang": "en",
      "source": "wikipedia_en"
    }

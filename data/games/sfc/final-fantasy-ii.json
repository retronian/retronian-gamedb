  "descriptions": [
    {
      "text": "The fourth entry in the Final Fantasy series was released as Final Fantasy II in the West, because the second and the third games were not released there at the time. The game is a Japanese-style RPG with top-down world map navigation, automatic leveling up, and random enemy encounters.",
      "lang": "en",
      "source": "igdb"

  "descriptions": [
    {
      "text": "Putty is a platform game where the lead character is... a blob of putty. He has been expelled from Putty Moon by Dazzledaze the wizard and his assistant Dweezil the Cat. Your job is to lead the character round the platform levels making use of his special abilities to rescue and destroy.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Putty (also known as Silly Putty or Look Out It's...Putty) is a game developed by System 3 and released in 1992 for the Amiga. It was also released on the Super Nintendo Entertainment System in 1993 as Super Putty (Putty Moon (パティームーン, Patī Mūn) in Japan) and Amiga CD32 version was published in 1994 under the same name.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

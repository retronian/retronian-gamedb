  "descriptions": [
    {
      "text": "DICE’s first game was built by five friends from the Amiga demo group The Silents in their spare time. What started out as a demo idea soon became a full-fledged pinball simulation published by 21st Century Entertainment with the Amiga as the primary platform. Pinball Dreams captivated gamers and quickly became a cult hit.",
      "lang": "en",
      "source": "igdb"
    }
  ]

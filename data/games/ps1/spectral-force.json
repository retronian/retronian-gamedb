  "descriptions": [
    {
      "text": "Spectral Force is the first in a long series of tactical role-playing games. This is a war simulation game set in \"Neverland\", where humans, gods, and the demon clans each wage war over the continents for their own visions of unity.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "This is a war simulation game set in \"Neverland\", where humans, gods, and the demon clans each wage war over the continents for their own visions of unity. Over 200 characters and interweaving events. The first installment of a simple-to-play series. Even now, many sequels and updated editions continue to be made.",
      "lang": "en",
      "source": "igdb_storyline"

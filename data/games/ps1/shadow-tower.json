  "descriptions": [
    {
      "text": "Shadow Tower is a first-person view action role-playing game developed by From Software and released in 1998. It shares many similarities with the King's Field series of games.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player controls mercenary Ruus Hardy, who, upon visiting the town of Zeptar, finds it razed to the ground. The towns inhabitants have been killed, and their souls claimed by evil spirits lurking below a nearby tower. Ruus heads alone into the underground dungeon to slay the monsters and set the souls free. This journey will take the player through six \"worlds\" based on nature, including Earth, Fire, Illusion, and Death, and pit them against monsters and bosses alike.",
      "lang": "en",
      "source": "igdb_storyline"
    },

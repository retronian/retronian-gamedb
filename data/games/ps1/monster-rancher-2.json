  "descriptions": [
    {
      "text": "Monster Rancher 2 (released 1999) is a video game and the second North American and Japanese installment in the Monster Rancher series. In Europe (and other PAL locations) Monster Rancher 2 is the first release in the series and is thus named Monster Rancher.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "This game involves raising, fighting, and breeding monsters. The main character is never seen on screen and never talks to anyone directly. Instead, all of the dialog and action is done by the trainer's assistant Colt and her toucan Joy. The player chooses his actions and choices through menu options.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "Um Jammer Lammy is a rhythm-based game that takes place in the PaRappa world and tells the story of the all-girl pop rock band, MilkCan. The game has very humorous and catchy music tracks, co-op gameplay, and a plethora of unlockables.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Where Lammy goes, mosh pits follow. She's the guitar-slinging megastar of an all-chick band called MilkCan. Help Lammy make it to her big gig on time by jamming to rock, heavy metal, punk, pop and other killer riffs. You can even take on another player with an awesome two-player mode.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "This game takes place during the 1995 PGA Tour season. The game features many professional golfing stars and various modes from stroke play to match play and even tournament mode. Golf clubs are assigned automatically by the caddy as the computer deems suitable for every lie and every situation.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "PGA Tour 96 is a sports video game developed by Hitmen Productions for the PlayStation, MS-DOS, Sega Genesis, and Windows versions, Unexpected Development for the Game Boy version, NuFX for the Sega Genesis and 3DO versions, Ceris Software for the Game Gear version, and Polygames for the SNES version and published by EA Sports for PlayStation, MS-DOS, Windows, Game Boy, Sega Genesis, 3DO, Game Gear, and SNES.",
      "lang": "en",
      "source": "wikipedia_en"
    }

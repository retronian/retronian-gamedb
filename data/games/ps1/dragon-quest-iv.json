  "descriptions": [
    {
      "text": "Dragon Quest IV was remade for the Sony PlayStation in Japan. It was developed by Heartbeat and published by Enix. The remake was developed using Dragon Quest VII: Fragments of the Forgotten Past 's 3D graphics engine. With this remake came new features; among them were a new chapter, a new character, a boom town reminiscent of VII's, an inter-party talk command similar to Dragon Quest VII, and the ability to turn off the artificial intelligence for party members. The Enix of America Corporation originally planned to bring the remake to North America in 2002, but it was later cancelled due to Heartbeat closing its video game development operations.",
      "lang": "en",
      "source": "igdb"
    },

  "descriptions": [
    {
      "text": "A remake of Dai-3-ji Super Robot Taisen for the PlayStation, first released first in Super Robot Taisen Complete Box, then separately as a standalone release.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game take place after the 2nd Super Robot Wars, the Divine Crusaders reformed under the leadership of the Zabi family, led by Gihren Zabi, who plans to use the DC to create a dictatorship. However, as the Federation tries to deal with the resurgence of the DC, a new foe appears, the aliens which Bian Zoldark warned of.",
      "lang": "en",
      "source": "igdb_storyline"
    }

  "descriptions": [
    {
      "text": "A strategy game for the PlayStation unrelated to the popular anime and manga series One Piece.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The story revolves around a successful landlord called Polpo. At the start of the game, Polpo's little sister is kidnapped by the owner of a rival mansion, Chocola. It is the player's job to battle through levels meeting Chocola's objectives and to eventually free Polpo's little sister.",
      "lang": "en",
      "source": "igdb_storyline"

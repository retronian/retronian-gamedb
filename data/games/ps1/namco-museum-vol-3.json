  "descriptions": [
    {
      "text": "Namco Museum Vol. 3 (ナムコミュージアム VOL.3, Namuko Myūshiamu Vol. 3) is a video game compilation developed by Now Production for PlayStation in 1996-1997. It is the third game in the Namco Museum series.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "ナムコミュージアム VOL.3（Namco Museum Vol. 3）は、1996年から1997年にかけて、ノウ・プロダクションがプレイステーション向けに開発したビデオゲームコンピレーション作品で、ナムコミュージアムシリーズの第3作にあたります。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

  "descriptions": [
    {
      "text": "The Emperor's New Groove is a video game based on the 2000 Disney film of the same name, developed by Argonaut Games for the PlayStation and Microsoft Windows.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game loosely follows the plot of the film, from which it also includes a number of video clips. Emperor Kuzco has been transformed into a llama by his evil advisor Yzma, who has subsequently taken over his throne. Kuzco befriends the peasant Pacha, and together they seek to confront Yzma and obtain an elixir that will return Kuzco to his human form.",
      "lang": "en",
      "source": "igdb_storyline"
    },

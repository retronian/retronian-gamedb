  "descriptions": [
    {
      "text": "Simple 1500 Series Vol. 55: The Darts features a complete 3d simulation of the darts sport with game modes like 301, 501, cricket, etc. The game uses the analog stick for a more realistic simulation.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player takes the role of a superhero in a futuristic city where he got to defeat evil people using the darts as his only weapon. There are darts combats in bars and some mini games where the player has to free hostages or catch robbers using his darts.",
      "lang": "en",
      "source": "igdb_storyline"
    }

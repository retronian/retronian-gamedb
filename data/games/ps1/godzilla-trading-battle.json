  "descriptions": [
    {
      "text": "Godzilla Trading Battle is a PlayStation video game released only in Japan in 1998 by Toho Co., Ltd. It featured almost every Toho kaiju up to that point as well as 6 new monsters created exclusively for the game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Using cards featuring monsters from all reaches of Godzilla and Toho lore, the player must help defend the Earth from a hostile alien invasion.\n\nAfter defeating the Story mode, the player can access duels and earn even more and rarer cards.",
      "lang": "en",
      "source": "igdb_storyline"

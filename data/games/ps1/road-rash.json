  "descriptions": [
    {
      "text": "Road Rash is the third entry in the vehicular combat/racing series of the same name. It was first released on 3DO Interactive Multiplayer in 1994, received a demake of sorts on the Sega CD in 1995, and then finally arrived to Sony PlayStation, Sega Saturn and Microsoft Windows in 1996. Not to be confused with the original 1991 title on Sega Genesis/Mega Drive.",
      "lang": "en",
      "source": "igdb"

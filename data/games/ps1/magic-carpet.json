  "descriptions": [
    {
      "text": "Magic Carpet is a video game released by Bullfrog Productions in 1994. Its graphics and gameplay were considered innovative and technically impressive at the time. A revised edition, Magic Carpet Plus, included the Hidden Worlds expansion pack which added 25 levels and a winter-themed tileset. The title also had a sequel released in 1995, Magic Carpet 2. Magic Carpet was considered by critics to be a revolutionary game for its time.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player plays a wizard (on a magic carpet) flying over water, mountains, and other terrain while destroying monsters and rival wizards (which are controlled by the computer) and collecting \"mana\" which is gathered by hot air balloons and stored in the player's own castle.",
      "lang": "en",
      "source": "igdb_storyline"
    },

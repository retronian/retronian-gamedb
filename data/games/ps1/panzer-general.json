  "descriptions": [
    {
      "text": "You are the brightest and best of the new Axis generals in the Second World War. Your tactical skills will be tested in armored assaults, amphibious invasions, paradrops, naval engagements, and fierce aerial combat for control of the skies. Go from triumph to triumph, invading and seizing the capitals of Great Britain, the Soviet Union, and ultimately the United States of America on your way to conquering the whole world! Can you achieve a place in history?",
      "lang": "en",
      "source": "igdb"

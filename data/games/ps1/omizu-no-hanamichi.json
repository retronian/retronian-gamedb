  "descriptions": [
    {
      "text": "A PlayStation video game based on a Japanese TV drama of the same name.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player takes the role of a young man that is hired in the Paradise Club to take care of the girls that works there at night, and to do that he have to check them while they are working and see if he can make their work better when they are talking with the different men, if he do the job right they will earn more points that at the end of each week he can use to buy new presents (like perfumes, jewels, etc) that the girls will use in their job.",
      "lang": "en",
      "source": "igdb_storyline"

  "descriptions": [
    {
      "text": "The arcade classic is taken to the next level, this time in 3D. The super-enhanced hero Ugene is once again called into action to save the last human family against the hordes of relentless Robotrons. Battle through 100 different levels, gaining new power-ups and abilities as Ugene survives wave after wave of the unrelenting hordes. While Ugene may face the familiar Robotrons, there will be new additions and tricks that the killer robots will use against the last surviving human family. Ugene must protect them at all cost while racking up the highest possible score!",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Robotron X is a twin-stick shooter video game co-developed by Leland Interactive Media and Player 1 and it was released by Midway Games in November 1996 for the PlayStation. It is a 3D version of the 1982 arcade video game Robotron: 2084. GT Interactive published a Windows port in 1997. A Nintendo 64 version was released in 1998 as Robotron 64, and Crave Entertainment bought out the publishing rights to the N64 version.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

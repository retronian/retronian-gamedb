  "descriptions": [
    {
      "text": "The second Doraemon game released for the PlayStation. A side-scrolling platform action game where you control Doraemon, Nobita & friends as they take the role of famous fairy tale characters.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Doraemon has brought a giant television from the future for Nobita and his friends to watch, but when they turn it on to watch some famous fairy tales, they find that all the heroes have been captured by an evil demon! Using another device, Doraemon transforms each of his friends into one of the famous heroes, and they enter the storybook world to rescue the captured heroes.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "Bust a Groove 2 is a hybrid music/fighting game released in 2000 for the Sony PlayStation and is the sequel to Bust a Groove. The game was originally released in Japan as Bust a Move 2: Dance Tengoku Mix, and was never released in Europe.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game takes place one year after the previous installment and shares the same overall gameplay. It combines dance moves and special abilities designed to damage the opponent. It also features new songs, new characters and updated costumes for the returning characters retained from the previous game.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "Dancing Stage Featuring True Kiss Destination (ダンシングステージフィーチャリングトゥルーキスデスティネーション, Danshingu Suteji Fīcharingu Tourū Kisu Desutinēshon) is the first \"Dancing Stage\" title of the Dance Dance Revolution series released in Japan and other parts of Asia on July 27, 1999. The Dancing Stage games in Japan all deviate away from the main DDR series of games and for True Kiss Destination, it features a themed set of music by the Japanese group of the same name as well as original music from Konami's in house artists.",
      "lang": "en",
      "source": "igdb"
    }

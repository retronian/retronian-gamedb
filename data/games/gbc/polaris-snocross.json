  "descriptions": [
    {
      "text": "Polaris SnoCross is a snocross snowmobile racing game for Game Boy Color, PlayStation, Nintendo 64, and later Microsoft Windows. It was released in 2000. French publisher Wanadoo Edition released a budget version of the game for the PC in 2001, called SnowCross.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Polaris SnoCross』は、Game Boy Color、PlayStation、Nintendo 64、そして後にMicrosoft Windows向けに発売されたスノークロス（スノーモービルレース）ゲームです。2000年に発売されました。フランスのパブリッシャーであるワナドゥ・エディションは、2001年にPC向けに低価格版の『SnowCross』をリリースしました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

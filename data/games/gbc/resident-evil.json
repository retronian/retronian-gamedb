  "descriptions": [
    {
      "text": "Resident Evil was planned for a GameBoy Color adaptation in a project outsourced to British company HotGen Studios, Ltd. Intended for an Autumn 1999 release, it was repeatedly delayed due to programming issues, and ultimately cancelled in March 2000 in favour of M4, Ltd.'s alternate proposal for a new game made from the ground-up for the console, which became Resident Evil: Gaiden.",
      "lang": "en",
      "source": "igdb"
    }

  "descriptions": [
    {
      "text": "In this game, the film's hero, Gizmo, attempts to find the gremlins and capture them all. In the meantime, the sinister Stripe and his army of 30 different gremlins decide to invade the town of Kingston Falls and try to transform Gizmo into a gremlin. The game can be played as either character. Gremlins: Unleashed! features 10 levels based in locations featured in the film, including Billy's house, the school laboratory, the department store, and the movie theater.",
      "lang": "en",
      "source": "igdb"
    }

  "descriptions": [
    {
      "text": "バックギャモン、世界で最も広くプレイされ認知されているボードゲームがポータブルになりました。運とスキルの究極のゲームがゲームボーイで登場。プレイモードは「トーナメント」「フリー」「対戦マッチ」の3種類から選べ、難易度は6段階あります。",
      "lang": "ja",
      "source": "romu"
    },
    {
      "text": "Backgammon is a Game Boy Color version of the board game.",
      "lang": "en",
      "source": "igdb"
    }
  ],

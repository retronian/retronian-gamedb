  "descriptions": [
    {
      "text": "Micro Maniacs is a racing video game developed by Codemasters for PlayStation and Game Boy Color. It is a spin-off to the Micro Machines games, the main difference being that players control tiny characters where a few racetracks feature the use of vehicles. The North American PlayStation release was sponsored and endorsed by Fox Kids, branding the game in the region as FoxKids.com Micro Maniacs Racing. It was scheduled to be released in June 2000, but was delayed to late September.",
      "lang": "en",
      "source": "wikipedia_en"

  "descriptions": [
    {
      "text": "Help Sulley and Mike find all the pieces of Boo's door as they search through the colorful Monstropolis while avoiding being caught by the Child Detection Agency!",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Boo has accidentally returned to Monstropolis. Luckily, Sulley finds Boo before she could fall into the hands of the CDA and Randall! Only you can help Sulley and Mike find the door that can get Boo back home!",
      "lang": "en",
      "source": "igdb_storyline"

  "descriptions": [
    {
      "text": "Test Drive 6 is a 1999 racing video game developed by Pitbull Syndicate for PlayStation, Microsoft Windows and Dreamcast. In the United States, the game was published by Infogrames North America, while it was published in Europe by Cryo Interactive. The game features 37 licensed cars, plus four police car variants. As a first for the series, cars from General Motors are not playable in this game due to licensing issues, instead appearing as traffic cars. The soundtrack featured industrial rock and techno music from artists such as Fear Factory, Lunatic Calm and Cirrus.\nA Game Boy Color version was developed by Xantera, a small developer that also developed other Test Drive titles for the handheld.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

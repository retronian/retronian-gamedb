  "descriptions": [
    {
      "text": "Star Wars: Episode 1 - Racer lets you participate in the famous pod race sequence that was the critical highlight of the 1999 film Star Wars: Episode I, The Phantom Menace. These lightning-quick vehicles are capable of reaching simulated speeds of up to 600 miles per hour while skimming a mere 4 feet above the ground. The Game Boy Color version of the game is a top-down racer that faces you against one other rival podracer, in single player or multiplayer with a link cable.",
      "lang": "en",
      "source": "igdb"

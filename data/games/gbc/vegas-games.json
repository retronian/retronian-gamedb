  "descriptions": [
    {
      "text": "Vegas Games 2000, known as Vegas Games: Midnight Madness, Midnight in Vegas in Europe and Vegas Games on Game Boy Color, is a gambling simulation video game. It was released on Microsoft Windows in 1998, then released in 2000 on PlayStation and Game Boy Color. New World Computing, who developed the PC version, had previously published Vegas Games and several other Vegas Games titles.",
      "lang": "en",
      "source": "wikipedia_en"

  "descriptions": [
    {
      "text": "The Game Boy version of Montezuma's Return! with a Metroidvania-style gameplay plays more like the original Montezuma's Revenge.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Max Montezuma is a soldier descended from an ancient Aztec emperor. Max stumbles across a deserted, uncharted island, and accidentally crashes his plane on it. Prior to Max's arrival, the island is undiscovered. Max only has a flashlight, canteen, and an entire lost Aztec civilization before him. He must restore the desecrated tomb of his ancestors, discover the link between the ancient Aztecs and a race of saucer-flying aliens, and more, in his adventure.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

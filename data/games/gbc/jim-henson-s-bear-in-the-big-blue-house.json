  "descriptions": [
    {
      "text": "Jim Henson's Bear in the Big Blue House is a 2002 video game published by Ubi Soft for the Game Boy Color and PlayStation, based on The Jim Henson Company and Disney Channel children's television show of the same name. A title for the Game Boy Advance was planned by Ubi Soft, but never released.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "ジム・ヘンソンによる『ベア・イン・ザ・ビッグ・ブルー・ハウス』は、同名のジム・ヘンソン・カンパニーとディズニー・チャンネルの児童向けテレビ番組を原作とした、2002年にユービソフトからゲームボーイカラーとプレイステーション向けに発売されたビデオゲームである。ユービソフトはゲームボーイアドバンス版も企画したが、発売されることはなかった。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

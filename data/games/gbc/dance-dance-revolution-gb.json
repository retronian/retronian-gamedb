  "descriptions": [
    {
      "text": "ダンスダンスレボリューションGBは、ナウプロダクションが開発し、コナミが発売したアクションゲームで、2000年に日本でリリースされました。",
      "lang": "ja",
      "source": "romu"
    },
    {
      "text": "Dance Dance Revolution GB was the start of a DDR series for the Game Color. Instead of the usual dance pads, it came with a miniature finger pad that could be strapped onto the handheld.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The Dance Dance Revolution series started in 1998 and has grown to a large set of games in the franchise. This list of Dance Dance Revolution games documents games released, including systems, formats, and regions for which the games were released.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ],

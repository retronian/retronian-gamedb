  "descriptions": [
    {
      "text": "Unlike the first-person shooter for PC and Nintendo 64, the Game Boy Color version of Daikatana was a top-down action-adventure game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Daikatana stars Hiro Miyamoto, who is told that an enemy of his family, Kage Mishima, had stolen the Daikatana with the intention of using its time-warping abilities to change history. Mishima then kidnaps his friend Mikiko and attacks the family dojo.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "X-Treme Sports was a Canadian English language category 2 television channel owned by Canwest Media Inc., a division of Canwest Global Communications. X-Treme Sports aired a variety of programming primarily related to extreme sports.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "X-Treme Sportsは、Canwest Global Communicationsの部門であるCanwest Media Inc.が所有していた、カナダ英語圏のカテゴリー2テレビチャンネルでした。同チャンネルでは、主にエクストリームスポーツに関連した様々な番組が放送されていました。",
      "lang": "ja",
      "source": "ai_local_gemma4",

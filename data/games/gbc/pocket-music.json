  "descriptions": [
    {
      "text": "2002 video game",
      "lang": "en",
      "source": "wikidata"
    },
    {
      "text": "Pocket Music is a 2002 video game developed by Jester Interactive and published by Rage Games for the Game Boy Color and Game Boy Advance. The game is a handheld adaptation of the Music series of games released by the developer, and allows players to create tracks of music from pre-recorded samples using a grid-based interface.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ポケットミュージック』は、2002年にジェスター・インタラクティブが開発し、レイジ・ゲームズからゲームボーイカラーおよびゲームボーイアドバンス向けに発売されたビデオゲームです。本作は、開発元がリリースした『ミュージック』シリーズの携帯機向け作品であり、グリッドベースのインターフェースを使用して、プリレコーディングされたサンプルから楽曲を制作できるのが特徴です。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

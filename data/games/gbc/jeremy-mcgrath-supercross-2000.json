  "descriptions": [
    {
      "text": "Jeremy McGrath Supercross 2000 is a motocross racing video game developed by Acclaim Studios Salt Lake City and published by Acclaim Entertainment under their Acclaim Sports label for Nintendo 64, Game Boy Color, PlayStation and Dreamcast. It features eight stadium tracks, eight outdoor tracks, and an option for players to create their own custom tracks. In addition to having a racing game mode, players could perform dirt bike tricks in a stunt mode.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ジェレミー・マクグラス スーパークロス 2000』は、Acclaim Studios Salt Lake Cityによって開発され、Acclaim EntertainmentがAcclaim Sportsというレーベル名でNintendo 64、Game Boy Color、PlayStation、Dreamcast向けに発売されたモトクロスレーシングのビデオゲームです。本作には、スタジアムコースが8種類、屋外コースが8種類用意されており、プレイヤーは独自のカスタムコースを作成することも可能です。レースゲームモードの他に、スタントモードではダートバイクのトリックを披露することができます。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

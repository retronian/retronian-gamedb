  "descriptions": [
    {
      "text": "Jeff Gordon XS Racing is a 1999 racing video game for Microsoft Windows and Game Boy Color. The game features then three time NASCAR Winston Cup Series champion Jeff Gordon. The game's Game Boy version has link cable support.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ジェフ・ゴードン XS レーシング』は、1999年にマイクロソフト ウィンドウズおよびゲームボーイカラー向けに発売されたレースビデオゲームです。本作では、当時3度のNASCARウィンストンカップシリーズチャンピオンであったジェフ・ゴードンがフィーチャーされています。ゲームボーイ版にはリンクケーブル対応機能が搭載されています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

  "descriptions": [
    {
      "text": "Test Drive Off-Road 3 (4X4 World Trophy in Europe) is a racing video game developed and published by Infogrames North America for Microsoft Windows, PlayStation and Game Boy Color. A Dreamcast version was planned, but was cancelled due to release issues.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Test Drive Off-Road 3 (4X4 World Trophy in Europe)』は、Infogrames North Americaによって開発・発売されたレーシングビデオゲームで、Microsoft Windows、PlayStation、Game Boy Colorに対応しています。Dreamcast版も計画されていましたが、発売上の問題により中止となりました。",
      "lang": "ja",

  "descriptions": [
    {
      "text": "Pumuckls Abenteuer im Geisterschloss is a German Game Boy Color game based on a cartoon show titled Pumuckls Abenteuer.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Pumuckl is a small red hairy goblin from a German TV series. His major concern is to trifle with humans. In this game Pumuckl is invited to castle \"Gruselzinne\". But it is a trap. Again the blue \"Klabauterman\" is against Pumuckl. You play Pumuckl and have to find your way out of the castle.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

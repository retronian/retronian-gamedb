  "descriptions": [
    {
      "text": "Kaitou Saint Tail is an Action-RPG for the Sega Game Gear. It is based upon the 1995-1996 Saint Tail manga and anime series.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Kaitou Saint Tail is a 2D top-down arcade game with several puzzle-solving minigames. The game is based on manga/anime series with this same name. The player controls the main heroine from the series, Meimi Haneoka (who is a schoolgirl and a magic thief). She runs in a maze, avoids police, and collects cards (cards are required to use magic). She meets various characters from series and talks with them. She can play in several minigames - Columns clone, various puzzles, and simple flight on balloons.",
      "lang": "en",
      "source": "igdb_storyline"
    },

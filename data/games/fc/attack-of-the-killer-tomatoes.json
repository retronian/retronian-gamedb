  "descriptions": [
    {
      "text": "Attack of the Killer Tomatoes is a platformer game released for the Nintendo Entertainment System, and later ported to the Gameboy. It was developed by Imagineering and based on the children's cartoon Attack of the Killer Tomatoes: The Animated Series, which in kind was based off of the movie franchise Attack of the Killer Tomatoes.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Chad Finletter goes on a journey to stop the evil Dr. Putrid T. Gangreen from unleashing his Doomsday Tomato. Chad must fight through hordes of mutant tomatoes alone, as all others are too afraid to help him.",
      "lang": "en",
      "source": "igdb_storyline"
    },

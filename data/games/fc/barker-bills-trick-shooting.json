  "descriptions": [
    {
      "text": "Barker Bill's Trick Shooting was developed and published by Nintendo for the NES in 1990. It was loosely based on the cartoon show \"Barker Bill's Cartoon Show\", popular in the 1950s. The game is essentially a shooting gallery taking place in a carnival, utilizing Nintendo's Zapper gun. It was relatively successful, but was not regarded as a breakthrough game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player participates in four different carnival-style games using the Nintendo Zapper gun. These four games are shooting balloons; flying saucers; objects through windows; and all three previous types in one progression.",
      "lang": "en",
      "source": "igdb_storyline"

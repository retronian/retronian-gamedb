      "lang": "it",
      "source": "wikidata"
    },
    {
      "text": "Computerspiel aus dem Jahr 1983",
      "lang": "de",
      "source": "wikidata"
    },
    {
      "text": "компьютерная игра 1983 года",
      "lang": "ru",
      "source": "wikidata"
    },
    {
      "text": "jogo eletrônico de 1985",
      "lang": "pt",

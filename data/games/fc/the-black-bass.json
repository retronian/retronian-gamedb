  "descriptions": [
    {
      "text": "The Black Bass is a fishing game designed for the Nintendo Entertainment System by HOT B games and released in 1988. Although not presented as a sequel, this game is the second in the Black Bass series-the first game being a Japan-exclusive.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "In this basic fishing game, the player attempts to catch as many black bass as possible throughout the day. The game allows for beginner mode and ranked mode. The ranked mode requires a password, and allows the player to select a specific location on the lake to begin fishing.",
      "lang": "en",
      "source": "igdb_storyline"
    },

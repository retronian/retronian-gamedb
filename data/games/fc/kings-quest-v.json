  "descriptions": [
    {
      "text": "A stripped down version of the PC game of the same name. Changes include severely reduced visual fidelity, the removal of any voice acting, along with heavy censorship due to Nintendo of America's strict guidelines.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "As foretold by ancient warlords, King's Quest V has finally arrived to weed out the weak and immortalize the brave. The only question now is... which are you?",

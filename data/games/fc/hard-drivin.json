  "descriptions": [
    {
      "text": "A cancelled NES version of the arcade game that eschews real-time 3D in favor of prerendered graphics and 2.5D visuals.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Hard Drivin' is a sim racing arcade video game developed by Atari Games in 1989. Players test drive a sports car on courses that emphasize stunts and speed. It features one of the first 3D polygon driving environments via a simulator cabinet with a haptic vibrating steering wheel and a custom rendering architecture.",
      "lang": "en",
      "source": "wikipedia_en"
    }

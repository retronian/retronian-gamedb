  "descriptions": [
    {
      "text": "Jurassic Park is a top-down action-adventure game based on the blockbuster film. Players take on the role of Dr. Alan Grant, exploring the island, rescuing stranded workers, and battling escaped dinosaurs. The game features maze-like levels, limited ammo, and key-based progression, combining exploration and survival in a challenging prehistoric setting.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "JURASSIC PARK starts just after the T-Rex pushes the visitor's van into a pit. You play the role of Dr. Alan Grant, so you have to find Tim and Lex, take them to the visitor's center and get everybody out of the island. But this time it won't be half as easy as it was on the movie.",
      "lang": "en",
      "source": "igdb_storyline"
    },

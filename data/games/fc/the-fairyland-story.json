    {
      "text": "An NES/Famicom prototype of arcade game The Fairyland Story. It was never released.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The Fairyland Story is a 1985 platform video game developed and published by Taito for arcades. It was released only in Japan in July 1985. It serves as a spiritual predecessor to later Taito platform games, such as Bubble Bobble and The NewZealand Story. It has been ported to various home systems, and has seen releases in various Taito compilations.",
      "lang": "en",
      "source": "wikipedia_en"
    }

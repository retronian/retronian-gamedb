  "descriptions": [
    {
      "text": "ファイアーエムブレム外伝。フィールド探索が追加された異色作。",
      "lang": "ja",
      "source": "romu"
    },
    {
      "text": "The Continent of Valencia is split into two territories. To the north is the Kingdom of Rigel, home to followers of the Dark God Doma. To the south is the Kingdom of Sofia, where the Earth Goddess Mila is worshipped. When Rigel invades Sofia, two heroes, Arum and Cellica, raise an army to topple Rigel and the Dark God that is backing the conflict.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game follows two protagonists, lifelong friends Alm and Celica, over the course of five chapters and takes place in two kingdoms on the continent of Valentia: Rigel and Zofia. The world map is slowly revealed for players to traverse through the game's five chapters.",
      "lang": "en",
      "source": "igdb_storyline"
    },

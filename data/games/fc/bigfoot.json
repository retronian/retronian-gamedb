  "descriptions": [
    {
      "text": "Bigfoot is a monster-truck racing game developed by Beam Software Company for the Nintendo Entertainment System.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Bigfoot was loosely based after the monster truck of the same name featured in the cartoon segment The Power Team-which was a part of the Video Power 1990 television show. The game allowed the player to control the title truck while competing against The Growler and The Charger.",

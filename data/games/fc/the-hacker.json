  "descriptions": [
    {
      "text": "When a computer programming agency catches his friends, a computer hacker must go online into the virtual world in order to rescue them.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Michel Amato, better known by his stage name the Hacker, is a French electroclash and techno producer who has worked extensively with Miss Kittin. His work has been influenced by electronic artists like Kraftwerk, new wave artists such as the Cure and Depeche Mode, as well as the French rave scene of the early 1990s. His artist name comes from the Jeff Mills track of the same name.",
      "lang": "en",
      "source": "wikipedia_en"
    }

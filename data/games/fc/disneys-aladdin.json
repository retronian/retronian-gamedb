  "descriptions": [
    {
      "text": "The game from Virgin based on the 1992 animated Disney film is a side-scrolling platformer.\n\nThe player controls Aladdin, who must make his way through several levels based on locations from the movie: from the streets and rooftops of Agrabah, the Cave of Wonders and the Sultan's dungeon to the final confrontation in Grand Vizier Jafar's palace.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player controls Aladdin, who must make his way through several levels based on locations from the movie: from the streets and rooftops of Agrabah, the Cave of Wonders and the Sultan's dungeon to the final confrontation in Grand Vizier Jafar's palace. The Sultan's guards and also animals of the desert want to hinder Aladdin in his way.",
      "lang": "en",
      "source": "igdb_storyline"
    },

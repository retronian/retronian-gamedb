  "descriptions": [
    {
      "text": "The NES port of Karnov. In the game, players take control of the title character Jinborov Karnovski, or \"Karnov\" for short. Karnov is a strongman popularly illustrated as being from an unspecified part of the Soviet Union's Central Asian republics as shown on the original arcade flyer and again in Karnov's Revenge.",
      "lang": "en",
      "source": "igdb"

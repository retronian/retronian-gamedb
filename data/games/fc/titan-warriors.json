  "descriptions": [
    {
      "text": "Titan Warriors is a cancelled shoot-'em-up that was developed by Capcom for the NES / Famicom, in 1988. The game was meant to be a sequel of Vulgus, an arcade shooter developed and published by Capcom in Japan in 1984.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "\"Your Titan spacecraft is pitted against mutant alien invaders that are destroying the planet Vulgus. You must pursue the aliens through space and interplanetary obstacles to save the planet and your spacecraft.\"",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

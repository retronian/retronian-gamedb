  "descriptions": [
    {
      "text": "In Fisher-Price: Firehouse Rescue, the player controls a fireman driving a firetruck. Both the fireman and the firetruck bear the familiar style of the popular Fisher-Price toy line. The object of the game is to rescue pets from trees and people from houses in the immediate neighborhood. There are 2 parts to this task: the first part involves navigating the maze-like streets from an overhead perspective in order to find the troubled residence. Once the house is reached, the second part of the job is to maneuver the firetruck's ladder underneath the person or animal in need of rescue, from a side perspective, and letting them down to safety.",
      "lang": "en",
      "source": "igdb"
    }
  ]

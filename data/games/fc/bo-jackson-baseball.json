  "descriptions": [
    {
      "text": "Bo Jackson Baseball, known as TV Sports: Baseball in Europe, was released for the Nintendo Entertainment System and ported to the Amiga and IBM PC in 1990. The game is named after and features Bo Jackson, a professional baseball player in the 1980s.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Bo Jackson Baseball/TV Sports Baseball features a number of different modes, including exhibition, playoff, and CPU quick mode. The game uses city names, but the team names are fictional due to licencing issues. The players are also fictional, although some of the names are parodies of real-life players.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "MiG-29: Soviet Fighter is a shoot 'em up game developed by Codemasters in 1989 and released for several contemporary home computers. An unlicensed version was also released for the Nintendo Entertainment System by Camerica.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The player plays the role of a Soviet MiG-29 fighter pilot. The object of the game is to defeat the World Terrorist Army.",

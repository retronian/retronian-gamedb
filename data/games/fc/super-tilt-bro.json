  "descriptions": [
    {
      "text": "Every modern game system from Nintendo has an iteration of the Super Smash Bros series, but old systems seem forgotten. Super Tilt Bro is a homebrew for the NES porting the versus platformer style to our beloved system from the 1980's.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "You and a friend take control of a clone of Sinbad, the badass mascot of Ogre3D. Two fellows, one platform: you will have to fight to throw the other out.",
      "lang": "en",
      "source": "igdb_storyline"
    },
    {
      "text": "компьютерная игра 2020 года",
      "lang": "ru",
      "source": "wikidata"
    },
    {
      "text": "WTFPL, optionally-networked versus-platformer for the NES",
      "lang": "en",
      "source": "wikidata"
    }
  ]

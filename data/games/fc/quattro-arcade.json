  "descriptions": [
    {
      "text": "Quattro Arcade is a collection of four platform and action video games: CJ's Elephant Antics, a platformer; Stunt Buggies, a maze driving game; F16 Renegade, a shoot-em-up game; and Go! Dizzy Go! a platformer part of the Dizzy series.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Quattro is a series of video game compilations (each with four games) released in the 1990s. They consisted of games developed by Codemasters. The NES versions were released as multicarts and were published by Camerica without a license by Nintendo.",
      "lang": "en",
      "source": "wikipedia_en"
    }

  "descriptions": [
    {
      "text": "Dragon Warrior IV differs from the rest of the series by breaking up the game into five distinct chapters, each of which focuses on a different protagonist or protagonists. The first four are told from the perspective of the Hero's future companions and the fifth one, from the hero's perspective, brings all the characters together as they begin their journey to save the world.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game is divided into five chapters. The first four provide back-story for the Hero's party members, while the fifth follows the Hero themself as they meet up with the other characters.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

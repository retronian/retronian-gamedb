  "descriptions": [
    {
      "text": "A beat-'em-up game developed and published by Sega for the Sega Master System. It is a sequel to the SG-1000 game Dragon Wang (ドラゴン・ワン), in which the player reprises the role of Wang, a kung fu master.\n\nIn Brazil this game was re-released as Sapo Xulé O Mestre do Kung Fu in 1995, complete with graphical changes.\n\nThis can be played for free in the browser at the Internet Archive.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "This game is about a kid that has knowledge of kung fu including wall jumping. It tests his skills as he defeats terrible enemies in order to save the day.",
      "lang": "en",
      "source": "igdb_storyline"

  "descriptions": [
    {
      "text": "A shoot-'em-up designed for use with the Light Phaser, but can also be played with a control pad.\n\nNot to be confused with the Sega System 18 version.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Laser Ghost for the Sega Master System is completely different from the arcade original. In the game, players must protect a young girl named Catherine who is being held captive in the haunted White Manor. Using either the joypad or the Light Phaser gun, players eliminate the various hazards Catherine encounters as she attempts to escape with her soul.",
      "lang": "en",
      "source": "igdb_storyline"

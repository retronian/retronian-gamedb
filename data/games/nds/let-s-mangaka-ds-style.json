  "descriptions": [
    {
      "text": "A game based upon working your way up in the manga business. You use the DS to draw pictures.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "It has two modes: \"Story Mode\" where you can experience the life of a manga artist, and \"Drawing Mode\" where you can freely draw manga.\n\nIn story mode, you aim to become a popular manga artist, and while working as an assistant to a popular manga artist, you will hone your techniques and aim to become a popular manga artist.",
      "lang": "en",
      "source": "igdb_storyline"
    }

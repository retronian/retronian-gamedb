  "descriptions": [
    {
      "text": "Monster High: Ghoul Spirit is a 2011 party video game developed by ImaginEngine and published by THQ for the Nintendo DS and Wii consoles. It is loosely based on the Monster High line of dolls by Mattel.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Become a ghoul and attend Monster High to perform creeptastic tasks, build a freaky-fab reputation and vie for the prestigious title of Scream Queen.",
      "lang": "en",
      "source": "igdb_storyline"
    },

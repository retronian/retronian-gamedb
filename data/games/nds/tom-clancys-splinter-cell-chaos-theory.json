  "descriptions": [
    {
      "text": "You are Sam Fisher, the NSA's most elite black-ops agent. To achieve your mission you will kill from close range, attack with your combat knife, shoot with the prototype Land Warrior rifle, and use radical suppression techniques such as the inverted neck break. Also take on cooperative multiplayer infiltration missions, where teamwork is the ultimate weapon.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The year is 2008. Citywide blackouts ... stock exchange sabotage … electronic hijacking of national defense systems ... this is information warfare. To prevent these attacks, operatives must infiltrate deep into hostile territory and aggressively collect critical intelligence, closer than ever to enemy soldiers.",
      "lang": "en",
      "source": "igdb_storyline"
    },

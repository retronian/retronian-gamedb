  "descriptions": [
    {
      "text": "A 2D Platform Beat 'em up where players can change between the Go-Busters. Players collect ammo for their blasters which they can fire. the stages are linked and lead to boss battles where the Go-Busters use their Zords and Megazords in battles controlled by Quick Time Events.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Tokumei Sentai Go-Busters incorporates voice acting and has a story based from the said show. It also shows both strengths and weaknesses of the five characters and presents interactions with their respective partner Buddy Roid.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

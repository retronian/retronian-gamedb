  "descriptions": [
    {
      "text": "To-Fu: The Trials of Chi is a 2011 action puzzle video game developed and published by British studio HotGen for iOS. It was released by Devolver Digital for Android and Microsoft Windows and Rising Star Games for the Nintendo DS in 2012, as its first non-Serious Sam game. Two sequels were released, To-Fu 2 in 2011 and To-Fu Fury in 2014.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『To-Fu: The Trials of Chi』は、2011年にイギリスのスタジオHotGenによって開発・発売された、iOS向けのアクションパズルビデオゲームです。これは、初の『Serious Sam』シリーズ以外の作品として、2012年にAndroidおよびMicrosoft Windows向けにDevolver Digitalから、Nintendo DS向けにRising Star Gamesからリリースされました。続編として、『To-Fu 2』が2011年、そして『To-Fu Fury』が2014年にリリースされています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

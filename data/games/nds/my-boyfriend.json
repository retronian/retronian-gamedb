  "descriptions": [
    {
      "text": "My Boyfriend is a virtual life simulation game for the Nintendo DS where the player chooses a boyfriend, and pursues them through various activities and mini-games. The game includes story-driven missions, outfit collection, and exploration of locations such as a residential area, park, school, football pitch, skate park, and shopping center.",
      "lang": "en",
      "source": "igdb"

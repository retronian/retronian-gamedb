  "descriptions": [
    {
      "text": "Rhythm Heaven puts the music in your hands and some rhythm in your life. Let the music move you as you tap and slide your stylus on the touch screen to the beat of more than 50 musical rhythm games. The controls are as natural as tapping your finger to music.",
      "lang": "en",
      "source": "igdb"

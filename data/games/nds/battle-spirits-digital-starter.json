  "descriptions": [
    {
      "text": "Battle Spirits Digital Starter (バトルスピリッツ デジタルスターター) is the third Battle Spirits video game, and the first to appear on the Nintento DS. It was released August 5, 2010 in Japan, and is not licensed elsewhere.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The game follows a boy named Retsu Torai (渡雷 烈), though his name as well as physical appearance can be customized, in a setting similar to the Battle Spirits Shounen Toppa Bashin anime. He dreams of battling in the championships.",
      "lang": "en",
      "source": "igdb_storyline"
    }

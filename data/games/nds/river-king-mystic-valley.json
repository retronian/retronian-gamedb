  "descriptions": [
    {
      "text": "jeu vidéo de 2007",
      "lang": "en",
      "source": "wikidata"
    },
    {
      "text": "River King: Mystic Valley, known in Europe as Harvest Fishing and in Japan as Fishing Master of the River: Valley of Sunlight, Song of the Stream, is a 2007 fishing role-playing video game developed by Marvelous for the Nintendo DS. It is, currently, the most recent installment in the River King series, and follows an unnamed male protagonist as they explore a valley in order to find a fish, known as \"The River King\", that can cure their sister from an endless slumber.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『リバーキング：ミスティックバレー』は、ヨーロッパでは『ハーベストフィッシング』、日本国内では『フィッシングマスター・オブ・ザ・リバー：木漏れ日の谷』、または『せせらぎの歌』として知られる、2007年にマーベラスから開発されたニンテンドーDS用釣りシミュレーションRPGです。本作は、リバーキングシリーズの最新作にあたり、名前のない男性主人公が、永遠の眠りについてしまった妹を治すことができるとされる「リバーキング」と呼ばれる魚を探すため、ある谷を探検する物語を描いています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]
}

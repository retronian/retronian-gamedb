  "descriptions": [
    {
      "text": "Yu-Gi-Oh! 5D's World Championship 2010: Reverse of Arcadia's story mode proceeds with a parallel story arch from the animated series involving the reprise of the Dark Signers and their quest for supremacy over New Domino City. After being banned to the Underworld, these Earthbound Immortals will stop at nothing to overthrow the rule of New Domino City and destroy Satellite. To defeat them, players will enlist the help of some of their favorite characters from the Yu-Gi-Oh! universe! Compete in story mode or free duel mode against Jack, Yusei or any of the 20 new characters to take on the Dark Signers in an epic battle to settle the score between light and dark!",
      "lang": "en",
      "source": "igdb"
    },

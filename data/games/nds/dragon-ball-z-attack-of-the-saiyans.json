  "descriptions": [
    {
      "text": "The game follows the Saiyan Saga of the original DBZ story starting from the World Tournament and Goku's triumphant defeat of Piccolo. Players take the role of Goku and travel the DBZ universe from jungle to Snow Mountain on their quest to victory. Dragon Ball Z: Attack of the Saiyans features a host of original features which will be sure to thrill fans, such as brand new gameplay, unique game modes, fun side quests and content never before seen in either the anime or manga series.",
      "lang": "en",
      "source": "igdb"

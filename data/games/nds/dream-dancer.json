  "descriptions": [
    {
      "text": "Dream Dancer is a 1980 science fiction novel by American writer Janet Morris, the first in her Kerrion Empire trilogy. It was distributed in the US by Putnam in March 1981.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ドリーム・ダンサー』は、アメリカの作家ジャネット・モリスによる1980年のSF小説で、彼女のカーリオン帝国三部作の第一作にあたる。1981年3月にパットナム社から米国で刊行された。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

  "descriptions": [
    {
      "text": "Tinker Bell and the Great Fairy Rescue on Nintendo DS invites players to create their own fairy and fly into Fairy Camp and adventure through the English countryside and explore all new locations to find and grow the rare Rainbow Lily. Players will interact with Lizzy and team up with fairy friends to bring each of the six rare lilies to Fairy Camp. Along the way, fans will complete quests and take part in a wide variety of mini-games that will use specific fairy talents for arts and crafts, baking and decorating cookies and more. Connect to all the fun in Pixiehollow.com with new online connectivity features!",
      "lang": "en",
      "source": "igdb"
    }
  ]

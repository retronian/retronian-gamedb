  "descriptions": [
    {
      "text": "Petz: Dogz 2 is a virtual pet and home design game in the Petz series, released for the Nintendo DS in 2007. It is a localisation of the Japanese game Ocha-Ken no Heya DS (お茶犬の部屋DS), released in November 2006, and developed by MTO, as part of the Ocha-Ken media franchise—with colorful dogs of that series replaced with more realistic ones.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Petz: Dogz 2』は、2007年にニンテンドーDS向けに発売された、ペットシリーズに属する仮想ペットおよびホームデザインゲームです。これは、2006年11月に発売された日本のゲーム『お茶犬の部屋DS』のローカライズ作品であり、MTOが開発を担当しました。本作は、お茶犬メディアフランチャイズの一環として制作されており、シリーズのカラフルな犬たちがよりリアルな犬種に置き換えられています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

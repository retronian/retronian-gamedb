  "descriptions": [
    {
      "text": "Ys Strategy is a real-time strategy game developed by Future Creates exclusive to the Nintendo DS. It was published by Marvelous Interactive (now absorbed into its parent company, Marvelous Entertainment) in Japan and Rising Star Games in Europe. Its status in canon is unknown, as Falcom hasn't stated anything about it.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The story focuses on a young, red haired swordsman named Abel Renford, who allies himself with the Esteria kingdom. Joining forces with Princess Rione, it’s up to your army to defend the neighboring lands from the invading Romun Empire",
      "lang": "en",
      "source": "igdb_storyline"
    },

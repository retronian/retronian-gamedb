  "descriptions": [
    {
      "text": "Atsumare! Power Pro Kun no DS Koushien is an RPG baseball game for the Nintendo DS. It is part of the Jikkyō Powerful Pro Yakyū series of games by Konami and the sequel to Power Pocket Koushien. Players take control of high school baseball team in Japan, either as a player on the team or as a manager, and attempt to lead that team to the National High School Baseball Championship at Koshien Stadium. It is the first Pawapuro game for the DS to feature voice commentary.",
      "lang": "en",
      "source": "igdb"

  "descriptions": [
    {
      "text": "Help Sally spread her salon savvy from her hometown shopping mall to the glittering lights of Hollywood in this colorful and engaging challenge.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Sally's Salon, a virtual beauty salon click management-style game, provides players with an escape from the daily grind. In the game, Sally beautifies everyone from little old ladies to punk rockers in ten unique salon locations where players are challenged by 50 levels of frantic, but fashionable, fun. Players can direct Sally through a virtual beauty salon by performing beauty services, hiring employees, and customizing salon services.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

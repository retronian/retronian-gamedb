  "descriptions": [
    {
      "text": "Mystery Tales Time Travel allows players to venture on expeditions through time and solve a wide variety of mysteries. Follow a French writer who stumbles upon an old diary from a long lost relative.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Players must help Melanie solve riddles and find hidden objects in thirty unique locations around the world.",
      "lang": "en",
      "source": "igdb_storyline"
    }

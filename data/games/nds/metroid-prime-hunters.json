  "descriptions": [
    {
      "text": "Metroid Prime Hunters is a first-person action-adventure game that combines exploration, shooting, and competitive multiplayer gameplay. Set across interconnected locations, it features objective-based progression alongside encounters with rival bounty hunters, each with distinct abilities and weapons.\nThe game emphasizes fast-paced combat, environmental navigation, and upgrade-driven progression, with both single-player and multiplayer modes supporting a variety of playstyles.",
      "lang": "en",
      "source": "igdb"

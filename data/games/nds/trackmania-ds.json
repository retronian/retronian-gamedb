  "descriptions": [
    {
      "text": "TrackMania DS is a racing video game developed by Firebrand Games. It was published by Focus Home Interactive in Europe and released for the Nintendo DS on November 14, 2008, and in the United States by Atlus USA on March 17, 2009. The game received generally favorable reviews from critics.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『トラックマニアDS』は、Firebrand Gamesが開発したレーシングビデオゲームです。ヨーロッパではFocus Home Interactiveによって発売され、2008年11月14日にニンテンドーDS向けにリリースされました。一方、アメリカ合衆国ではAtlus USAによって2009年3月17日に発売されました。本作は、批評家から概ね好意的なレビューを受けました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

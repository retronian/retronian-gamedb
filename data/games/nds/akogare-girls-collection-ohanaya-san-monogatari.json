  "descriptions": [
    {
      "text": "Akogare Girls Collection: Ohanaya-San Monogatari is a Strategy game, developed and published by Columbia Music Entertainment, which was released in Japan in 2011.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Ohanaya-san Monogatari, or \"Flower Shop Story\" is a career simulator that puts you in the shoes of a girl whose mother has to go overseas. This causes her to have to open their new flower shop all by herself.",

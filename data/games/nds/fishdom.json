  "descriptions": [
    {
      "text": "Fishdom is a puzzle game developed by Playrix for Microsoft Windows, Mac OS, Nintendo DS, Nintendo 3DS, Android, iOS, and iPadOS. The game was originally launched on 19 June 2008.",

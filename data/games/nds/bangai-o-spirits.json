  "descriptions": [
    {
      "text": "Bangai-O Spirits provides gamers with addictive shooter gameplay, punishing supermoves and a sensory overload of fireworks onscreen, with strategic and tactical elements and TREASURE's quirky design style. The game also offers co-op, competitive multiplayer for 1-4 players via local wireless, a powerful level editor tool which allows players to edit in-game levels or create new ones from scratch, and the revolutionary new ability to transfer data among DS systems through sound data transfer technology known as Sound Load.",
      "lang": "en",
      "source": "igdb"

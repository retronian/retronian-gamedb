  "descriptions": [
    {
      "text": "Littlest Pet Shop: Winter is a virtual pet game where players collect and customize 20 different pets across four themed environments. Players earn Kibble Coins through 16 mini-games to unlock new pets, accessories, and playsets. The game features different pet categories including Fanciest, Cuddliest, Sportiest, and Chilliest, with over 100 accessories available for customization.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Littlest Pet Shop brings the magic of owning your own pet shop to your home. EA brings the quirkiness and cuteness of the popular Hasbro girl-s brand to life in a new digital world. Players can explore three unique environments as they unlock new pets, playsets, accessories, and more.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

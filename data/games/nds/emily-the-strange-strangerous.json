  "descriptions": [
    {
      "text": "Best described as \"Professor Laytons Neice\" Emily is a a young teenage that is on a quest to find her four missing cats. To do so you must solve crypt puzzles and mini games to progess the story",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Emily wakes up by CHZ after a nightmare in which her cats were catnapped by a mysterious unknown person. No doubt a strange dream even for \"the Strange\", but when she finds that her cats are really nowhere to be found, she sets out to disappear herself and find them.",
      "lang": "en",
      "source": "igdb_storyline"
    }
  ]

  "descriptions": [
    {
      "text": "Days of Memories is a compilation of the first three of SNK Playmore's dating simulation games.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Set against the backdrop of the old, romantic city of Kyoto, your aim is to shorten the distance between you and the girls. The complex plot is like a tree with numerous branches that intersect each other, each decision you make is going to affect the outcome of your relationships, see past the girls' pretenses and make the correct choices.",
      "lang": "en",
      "source": "igdb_storyline"
    }

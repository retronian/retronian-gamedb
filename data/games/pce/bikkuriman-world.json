  "descriptions": [
    {
      "text": "A version of the arcade game Wonder Boy in Monster Land by developer Westone. Unlike other ports of this game, this version was developed by Westone themselves, but re-themed to use the setting of the anime Bikkuriman, which started airing around the time of released. It is one of the two launch titles for the PC Engine.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The evil Shizo Jura has taken over the kingdom. Super Zeus tasks the hero Head Rokoko to challenges his many underlings on his journey to the castle to reclaim the kingdom.",
      "lang": "en",
      "source": "igdb_storyline"
    }

  "descriptions": [
    {
      "text": "This game belongs in the Baseball Hall of Fame. Nothing takes you out to the ballgame like World Class Baseball! It tests all your baseball knowledge and skills. Bunt. Throw a slider. A change-u. Pick runners off base. Call in a relief pitcher. Hear the roar of the crowd and the crack of the bat. Play another player. Play against the computer. Play the Turbo Champs. Knock the dirt from your spikes. You're up!",
      "lang": "en",
      "source": "igdb"

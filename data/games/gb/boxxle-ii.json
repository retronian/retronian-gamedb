  "descriptions": [
    {
      "text": "Boxxle 2 is a puzzle game in which you have to push crates from point A to point B without getting them stuck.\n\nThe player must maneuver boxes in a warehouse in order to make enough money to woo his desired girlfriend.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Boxxle II is a 1990 sokoban puzzle video game for the Game Boy developed by Atelier Double Co.. It was published by Pony Canyon in Japan and FCI in the United States. It is the sequel to the 1989 Game Boy title Boxxle.",
      "lang": "en",
      "source": "wikipedia_en"
    }

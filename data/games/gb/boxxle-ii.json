  "descriptions": [
    {
      "text": "Boxxle II is a 1990 sokoban puzzle video game for the Game Boy developed by Atelier Double Co.. It was published by Pony Canyon in Japan and FCI in the United States. It is the sequel to the 1989 Game Boy title Boxxle.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Boxxle II』は、アトリエ・ダブル・コーが開発した、1990年のゲームボーイ用ソコバンパズルビデオゲームです。日本国内ではポニーキャニオンが、アメリカ合衆国ではFCIが発売しました。本作は、1989年に発売されたゲームボーイ用タイトル『Boxxle』の続編にあたります。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

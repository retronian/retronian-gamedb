  "descriptions": [
    {
      "text": "Tiny Toon Adventures: Wacky Sports (Tiny Toon Adventures 3: Doki Doki Sports Festival in Japan), released in 1994 on the Nintendo Game Boy and developed and published by Konami, is the third Tiny Toon Adventures-related game for the system.\n\nThe player chooses either Buster Bunny or Babs Bunny and participates in their choice of sports activities, including baseball, soccer, or tennis. As Buster, they can also play carnival games set up by characters such as Shirley the Loon and Fifi La Fume. Carnival games include a watergun gallery and a beat-the-clock challenge featuring Elmyra Duff.",
      "lang": "en",
      "source": "igdb"
    }

  "descriptions": [
    {
      "text": "Dropzone is a horizontally scrolling shooter developed by Archer Maclean (under the name Arena Graphics) for Atari 8-bit computers and published in 1984 by U.S. Gold. It was ported to the Commodore 64, and later released for the Nintendo Entertainment System, Game Boy, Game Gear, and Game Boy Color. Ports for Master System and Sega Genesis were also announced, but never released.\nMaclean's first commercial game, Dropzone is similar in gameplay and style to the arcade game Defender and borrows many elements, including the same style of font, aliens, and title screen.",
      "lang": "en",
      "source": "wikipedia_en"
    }

  "descriptions": [
    {
      "text": "NHL 95 (also known as NHL Hockey 95) is an ice hockey video game published by EA Sports. It was released in 1994 for the Super Nintendo Entertainment System and the Sega Genesis. The team rosters and player attributes in the game reflect that of the 1994–95 NHL season.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "NHL 95（NHL ホッケー 95としても知られる）は、EA Sportsが発売したアイスホッケーのビデオゲームです。本作品は1994年にスーパーファミコンとセガジェネシス向けに発売されました。ゲーム内のチームロースターや選手の能力値は、1994-95シーズンのNHLを反映しています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

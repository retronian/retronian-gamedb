  "descriptions": [
    {
      "text": "Track Meet, known in Japan as Track Meet: Mezase! Barcelona (トラックミート めざせ!バルセロナ), is a sports video game that was released for the original Game Boy. In Germany the game was released as Litti's Summer Sports (endorsed by Pierre Littbarski).",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『トラックミート めざせ！バルセロナ』として知られる『トラックミート』は、オリジナルのゲームボーイ向けに発売されたスポーツビデオゲームである。ドイツでは、ピエール・リッタースキーが推薦した『Litti's Summer Sports』というタイトルで発売された。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

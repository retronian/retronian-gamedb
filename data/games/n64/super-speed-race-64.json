  "descriptions": [
    {
      "text": "Super Speed Race 64 is an enhanced version of Automobili Lamborghini, released only in Japan.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Automobili Lamborghini is a 1997 racing video game developed and published by Titus France for the Nintendo 64. It is a successor to Lamborghini American Challenge.\nIn 1998, an improved version subtitled Super Speed Race 64 (スーパースピードレース64) was released in Japan only. This version was distributed by Taito, presented as a successor to the company's Speed Race series from the late 1970s and early 1980s. Improvements include a new difficulty level, the ability to freely customize controls, the introduction of weather, and actual pictures of various models of Lamborghini with their names displayed before the demo screen.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

  "descriptions": [
    {
      "text": "Air Boarder 64 is a futuristic hoverboard racing game for the Nintendo 64 developed by Human Entertainment and released in Japan and Europe in 1998. It was to be released under the name AirBoardin' USA in North America by ASCII Entertainment, but was cancelled.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Air Boarder 64』は、Human Entertainmentが開発し、1998年に日本とヨーロッパで発売された、ニンテンドー64用（の）未来的なホバーボードレースゲームです。北米ではASCII Entertainmentによって『AirBoardin' USA』という名前で発売される予定でしたが、中止となりました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

  "descriptions": [
    {
      "text": "Carmageddon II: Carpocalypse Now is a vehicular combat video game, the sequel to Carmageddon, and released in 1998 for Microsoft Windows. The game was developed by Stainless Games and published by Sales Curve Interactive in Europe and Interplay Entertainment in North America. Ports for Mac OS, PlayStation and Nintendo 64 (the latter as Carmageddon 64) were released in 1999. A 2D version for the Game Boy Color was released in Europe in 1999, and in North America in 2000 as Carmageddon.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『Carmageddon II: Carpocalypse Now』は、『Carmageddon』の続編にあたる車両戦闘ビデオゲームで、1998年にMicrosoft Windows向けに発売されました。本ゲームはStainless Gamesによって開発され、ヨーロッパではSales Curve Interactive、北米ではInterplay Entertainmentによって出版されました。Mac OS、PlayStation、Nintendo 64（後者は『Carmageddon 64』）のポート版が1999年にリリースされました。また、2D版が1999年にヨーロッパで、2000年に北米で『Carmageddon』として発売されました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

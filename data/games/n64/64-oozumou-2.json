  "descriptions": [
    {
      "text": "64 Ōzumō is a sumo wrestling simulation video game for the Nintendo 64 released in Japan on November 28, 1997. A sequel, 64 Ōzumō 2, was released on March 19, 1999.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『64大相撲』は、1997年11月28日に日本で発売された、ニンテンドー64用相撲シミュレーションビデオゲームである。その続編である『64大相撲2』は、1999年3月19日に発売された。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

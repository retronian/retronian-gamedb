  "descriptions": [
    {
      "text": "Extreme-G is a futuristic racing game with an emphasis on speed. It also features many weapons and an F-Zero style energy shield and regeneration.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Extreme-G is set in the distant future where Earth is reduced into a wasteland. From their new-found planet the human colonists watch their remote controlled bikes wreak havoc through their ancient cities and fight their way to determine which racer manages to qualify.",
      "lang": "en",
      "source": "igdb_storyline"
    },

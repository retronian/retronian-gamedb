  "descriptions": [
    {
      "text": "Out of the Vortex is an unreleased Sega Mega Drive game based on the 1993 comic series of the same name. It was never publicly announced, referenced or hinted at in any magazine or trade show event.\n\nTwo prototypes of the game were released by Hidden Palace. The first prototype was released on January 1, 2022, and a later prototype provided by Cryo Interactive Entertainment developer David \"Pipozor\" Saulnier was released on July 6, 2024.",
      "lang": "en",
      "source": "igdb"
    }

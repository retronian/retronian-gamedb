  "descriptions": [
    {
      "text": "The player alternatively assumes the roles of three members of the Able Squad: Lt. J.T. Marsh, Sgt. Rita Torres and Wolf Bronsky.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Exosquad is an American science fiction animated television series created by Universal Cartoon Studios for MCA TV's Universal Family Network syndicated programming block. The series ran for two complete seasons in syndication from 1993 to 1994. Reruns later aired on USA Network.",
      "lang": "en",
      "source": "wikipedia_en"
    }

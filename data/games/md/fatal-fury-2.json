  "descriptions": [
    {
      "text": "After Geese Howard's death in the original Fatal Fury, a mysterious nobleman becomes the sponsor of the new \"King of Fighters\" tournament. This time, the tournament is held worldwide with fighters around the globe competing. As the single player mode progresses, the mysterious challenger begins defeating the participants from the previous Fatal Fury game, searching for the man responsible for defeating Geese.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "After Geese Howard's death in the original Fatal Fury, a mysterious nobleman becomes the sponsor of the new \"King of Fighters\" tournament. This time, the tournament is held worldwide with fighters around the globe competing. As the single player mode progresses, the mysterious challenger begins defeating the participants from the previous Fatal Fury game (Michael Max, Hwa Jai, Duck King, Tung Fu Rue and Richard Meyer), searching for the man responsible for defeating Geese.",
      "lang": "en",
      "source": "igdb_storyline"

  "descriptions": [
    {
      "text": "A Sega Genesis port of arcade game After Burner II.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "After Burner II is an combat flight simulator released as an arcade video game by Sega in 1987. It is the second game in the After Burner series, and was released for the Sega X Board arcade system. In the game, players fly an F-14 Tomcat jet fighter, gunning down enemies while avoiding incoming fire. After Burner II came both a standard arcade cabinet and a servo actuated, sit-down motion simulator version which moved according to the motion of the plane onscreen. The cockpit would bank in the same direction the on-screen aircraft was banking. It is an updated version of After Burner, with the addition of throttle controls. It was a commercial success, becoming Japan's highest-grossing arcade game of 1988.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

  "descriptions": [
    {
      "text": "Rugby World Cup '95 is a sports video game developed by Electronic Arts and published by EA Sports for the Sega Genesis in 1994. It is based on the sporting event of the same name. A DOS port was developed by Creative Assembly and released in 1995.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "『ラグビーワールドカップ95』は、1994年にエレクトロニック・アーツが開発し、EAスポーツがセガ・ジェネシス向けに発売したスポーツビデオゲームです。これは、同名のスポーツイベントに基づいています。また、DOS版はクリエイティブ・アセンブリーによって開発され、1995年にリリースされました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }

  "descriptions": [
    {
      "text": "A series of 8 text-based games released exclusively in Japan for the Sega Game Toshokan download service. Each title revolves around one character, telling the backstories of every party member available to play as in Phantasy Star II.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Phantasy Star II Text Adventures were a series of eight text adventure video games available to users of Sega Game Toshokan, a modem for the Sega Mega Drive in Japan, and later released as part of a compilation on Mega CD. Each of the games takes place shortly before Phantasy Star II, documenting the backgrounds of its characters, and explaining what brings them to the town Paseo where they eventually team up to investigate the pervasive troubles of the Algol Solar System.",
      "lang": "en",
      "source": "igdb_storyline"
    },

  "descriptions": [
    {
      "text": "Davis Cup II (as named in the ROM header) is an unreleased sequel to Davis Cup Tennis, set to be released for the Sega Mega Drive. \n \nTwo prototypes of this game have been dumped - an earlier PAL version dated within the ROM as 1994-07-10, and a version for North America dated 1994-07-28. Both are early versions of the game with no music and many assets borrowed from the original Davis Cup Tennis.",
      "lang": "en",
      "source": "igdb"
    }

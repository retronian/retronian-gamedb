    },
    {
      "text": "World Series Baseball '95 is a 1994 baseball video game released by Sega for the Game Gear and Sega Genesis. A version for the 32X was released in 1996 under the name World Series Baseball Starring Deion Sanders.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "World Series Baseball '95 est un jeu vidéo de baseball sorti en 1995 sur Mega Drive. Le jeu a été développé par BlueSky Software puis édité par Sega.",
      "lang": "fr",
      "source": "wikipedia_fr"
    },
    {
      "text": "『ワールドシリーズベースボール '95』は、セガがゲームギアおよびセガジェネシス向けに1994年に発売した野球ビデオゲームです。32X用のバージョンは、1996年に『ワールドシリーズベースボール スターリング ディオン・サンダース』という名称で発売されました。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

  "descriptions": [
    {
      "text": "Powermonger is a real-time strategy video game developed by Bullfrog Productions and published by Electronic Arts. Originally released in 1990 for the Amiga and Atari ST, it was derived from the Populous engine but presented using a 3-dimensional game map.",
      "lang": "en",
      "source": "wikipedia_en"
    },
    {
      "text": "パワーモンガーは、ブルフロッグ・プロダクションズが開発し、エレクトロニック・アーツが出版したリアルタイムストラテジーゲームです。元々は1990年にアミガとアタリST向けに発売され、ポピュラス・エンジンを基に開発されましたが、3次元のゲームマップを用いて表現されています。",
      "lang": "ja",
      "source": "ai_local_gemma4",
      "base_lang": "en"
    }
  ]

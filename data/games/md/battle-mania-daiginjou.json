  "descriptions": [
    {
      "text": "Battle Mania Daiginjou is a shoot 'em up developed and published by VIC Tokai in 1993 for the Sega Mega Drive exclusively in Japan and South Korea. It is the sequel to Battle Mania (which was released in the US as Trouble Shooter).",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "A group calling itself the Kikokukyou have resurrected the leader of Blackball, the antagonist group of the original game, and the Trouble Shooters are called to stop Blackball and destroy Kikokukyou.",
      "lang": "en",
      "source": "igdb_storyline"
    },
    {
      "text": "Battle Mania Daiginjō is a 1993 horizontally scrolling shooter developed and published by Vic Tokai for the Mega Drive. It serves as a sequel to the original Battle Mania, which was released in North America under the title Trouble Shooter. Unlike the original Battle Mania, Daginjō was released exclusively for the Japanese and South Korean markets.\nBattle Mania Daiginjō had a limited print run and is consequently one of the most expensive Sega Mega Drive games today.",
      "lang": "en",
      "source": "wikipedia_en"
    }
  ]

  "descriptions": [
    {
      "text": "Allan Border cricket is a rebranded version of Graham Gooch's World Class Cricket. It is based on the sport of cricket played mainly in the British Commonwealth Countries. \n \nAll the international teams are present with full customization of player names, match modes and teams. Amateur, Professional and World Class make up the difficulty levels.  \n \nIt was released as Brian Lara Cricket for the Sega Genesis for the European Version.",
      "lang": "en",
      "source": "igdb"
    }

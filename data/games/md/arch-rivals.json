  "descriptions": [
    {
      "text": "Arch Rivals is a basketball game developed and published by Midway in 1989. The game introduces violence as an important part of the game, encouraging players to punch opposing players and stealing the ball from them. The game is regarded as the forerunner to Midway's popular arcade basketball game, NBA Jam.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "Players are able to select between a vareity of fictional teams and players. Games follow the standard basketball rules, with the exception of the accepted level of violence. The objective is to outscore the opponent. There are only two players on each team on the court, rather than the standard 5 men/team that is standard in basketballl.",
      "lang": "en",
      "source": "igdb_storyline"
    },
